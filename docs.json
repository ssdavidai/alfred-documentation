{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Alfred",
  "description": "API documentation for Alfred, your agentic butler",
  "colors": {
    "primary": "#f4ac3b",
    "light": "#ffbd59",
    "dark": "#d49a5b"
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  },
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://alfred.black",
    "mdx": {
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      }
    },
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "how-it-works",
              "architecture/infrastructure",
              "architecture/agent",
              "architecture/data",
              "architecture/semantic",
              "architecture/kinetic",
              "architecture/interface"
            ]
          },
          {
            "group": "Your Vault",
            "pages": [
              "vault/understanding-your-vault",
              "vault/record-types",
              "vault/vault-schema"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/billing",
              "guides/your-dashboard",
              "guides/using-the-inbox",
              "guides/browsing-your-vault",
              "guides/your-ai-agents",
              "guides/device-pairing",
              "guides/api-keys",
              "guides/how-the-api-works",
              "guides/recipes",
              "guides/intuition",
              "guides/monitoring",
              "guides/security"
